<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Posts</title>
    <style>
        body {
            background-color: beige;
        }

        .container {
            width: 100%;
            display: flex;
            flex-wrap: wrap;
            /* justify-content: center; */
            align-items: center;
        }

        h1 {
            text-align: center;
            margin: 20px 0;
            font-size: 36px;
            color: #333;
        }

        .add-btn {
            display: block;
            margin: 0 30px;
            padding: 10px 20px;
            background: #28a745;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

        .add-btn a {
            text-decoration: none;
            color: white;
            font-size: 16px;
            font-weight: 600;
        }

        .add-btn:hover {
            background: #218838;
        }

        .post {
            width: 400px;
            height: 400px;
            background: #fff;
            border-radius: 10px;
            padding: 15px;
            margin: 20px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
            font-family: Arial, sans-serif;
            overflow-y:unset;
            overflow-x: inherit;
        }
        .post p{
            width: 400px;
        }
        .post h3 {
            margin-bottom: 10px;
            font-size: 18px;
            color: #333;
        }

        .post h3 a {
            color: #007bff;
            text-decoration: none;
        }

        .post img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 10px;
        }

        .post .content {
            font-size: 15px;
            color: #555;
            line-height: 1.5;
        }

        .post p a {
            color: #6c757d;
            font-weight: bold;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .post form {
            display: inline-block;
            margin-right: 8px;
        }

        .post button {
            padding: 8px 18px;
            border-radius: 5px;
            border: none;
            font-weight: 600;
            cursor: pointer;
        }

        form[action*="edit"] button {
            background-color: #e7f3ff;
            color: #007bff;
        }

        /* Delete Color */
        form[action*="delete"] button {
            background-color: #fff0f0;
            color: #dc3545;
        }

        .post button:hover {
            opacity: 0.8;
        }
    </style>
</head>

<body>
    <h1>Blog App</h1>
    <button class="add-btn"><a href="http://localhost:8080/posts/new">Add new Blog</a></button>
    <div class="container">
        <% for(let post of posts){ %>
            <div class="post">
                <h3>Profile name: <a href="http://localhost:8080/posts/<%= post.id %>/profile">
                        @<%= post.username %>
                    </a>
                </h3>
                <img src="<%=post.img %>" alt="">
                <form method="get" action="posts/<%= post.id %>/edit">
                    <button>Edit</button>
                </form>
                <form method="get" action="posts/<%= post.id %>/delete">
                    <button>Delete</button>
                </form>
                <p>
                    <%= post.content %> <a href="http://localhost:8080/posts/<%= post.id %>/profile">See more</a>
                </p>
            </div>
            <%}%>
    </div>
</body>

</html>
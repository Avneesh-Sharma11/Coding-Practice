<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post in detail</title>
    <style>
        .po{
            padding: 20px;
            background-color: antiquewhite;
        }
    </style>
</head>
<body>
    <h1>Here is your post in detail</h1>
    <h3>post id : <%= post.id %></h3>
    <div class="po">
        <h2>@<%=post.username %></h2>
        <p><%= post.content %></p>
    </div>

</body>
</html>